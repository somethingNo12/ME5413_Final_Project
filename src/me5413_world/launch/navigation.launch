<launch>

  <!-- Connect the robot to a keyboard teleop controller -->
  <node name="teleop_twist_keyboard" pkg="teleop_twist_keyboard" type="teleop_twist_keyboard.py" output="screen" respawn="true"/>

  <!-- Run the map server -->
  <arg name="map_file" default="$(find me5413_world)/maps/my_map.yaml"/>
  <node name="map_server" pkg="map_server" type="map_server" args="$(arg map_file)" />

  <!-- Launch the AMCL Localizer -->
  <node name="amcl" pkg="amcl" type="amcl" output="screen"/>

  <!-- Launch Move Base -->
  <include file="$(find jackal_navigation)/launch/include/move_base.launch" />

  <!-- Fix sensor_frame: /front/scan publishes frame_id=tim551, not front_laser -->
  <param name="move_base/local_costmap/obstacles_layer/scan/sensor_frame"  value="tim551" />
  <param name="move_base/global_costmap/obstacles_layer/scan/sensor_frame" value="tim551" />

  <!-- Reduce inflation radius to prevent Jackal getting stuck in narrow passages -->
  <param name="move_base/local_costmap/inflater_layer/inflation_radius"  value="0.25" />
  <param name="move_base/global_costmap/inflater_layer/inflation_radius" value="0.25" />

  <!-- Override robot max speed -->
  <param name="move_base/TrajectoryPlannerROS/max_vel_x" value="2.5" />
  <param name="move_base/TrajectoryPlannerROS/min_vel_x" value="0.1" />

  <!-- Launch Rviz with our settings -->
  <node type="rviz" name="rviz" pkg="rviz" args="-d $(find me5413_world)/rviz/navigation.rviz" output="log" respawn="true"/>

  <!-- Publish initial pose (0,0,0) to kick-start AMCL, delayed 3s -->
  <node name="initial_pose_publisher" pkg="me5413_world" type="initial_pose_publisher"
        output="screen" launch-prefix="bash -c 'sleep 3; $0 $@'" />

  <!-- YOLOv5 cone detector (activated by /task_phase=4) -->
  <node pkg="yolov5_detector" type="block_detector_yolov5_node.py"
        name="block_detector_yolov5_node" output="screen">
    <param name="image_topic"  value="/front/image_raw" />
    <param name="output_topic" value="/blockornot" />
    <param name="conf_threshold" value="0.8" />
    <param name="publish_rate_hz" value="5.0" />
  </node>

  <!-- EasyOCR digit detector (activated by /task_phase=1) -->
  <arg name="enable_easyocr" default="true"/>
  <node if="$(arg enable_easyocr)"
        pkg="yolov5_detector"
        type="easyocr_digit_node.py"
        name="easyocr_digit_node"
        output="screen" />

  <!-- Phase-5 room digit detector (enabled by /room_digit_detector_enable) -->
  <node pkg="yolov5_detector"
        type="room_digit_detector_node.py"
        name="room_digit_detector_node"
        output="screen">
    <param name="image_topic" value="/front/image_raw" />
    <param name="enable_topic" value="/room_digit_detector_enable" />
    <param name="output_topic" value="/detectnumber" />
    <param name="conf_threshold" value="0.7" />
    <param name="min_votes" value="3" />
    <param name="detect_timeout_sec" value="4.0" />
  </node>

  <!-- Autonomous task executor (set auto_task:=false to disable) -->
  <arg name="auto_task" default="true"/>
  <node if="$(arg auto_task)"
        name="task_executor" pkg="me5413_world" type="task_executor.py"
        output="screen" required="false"/>

</launch>
