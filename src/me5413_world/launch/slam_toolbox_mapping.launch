<launch>

  <!-- Connect the robot to a keyboard teleop controller -->
  <node name="teleop_twist_keyboard" pkg="teleop_twist_keyboard" type="teleop_twist_keyboard.py" output="screen" respawn="true"/>
  
  <!-- Launch GMapping -->
  <include file="$(find slam_toolbox)/launch/online_async.launch" />

  <!-- Launch Rviz with our settings -->
  <node type="rviz" name="rviz_slam_toolbox" pkg="rviz" args="-d $(find me5413_world)/rviz/slam_toolbox.rviz" output="log" respawn="true"/>

</launch>
